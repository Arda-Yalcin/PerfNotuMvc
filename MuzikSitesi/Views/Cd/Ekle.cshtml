@model MuzikSitesi.Models.Cd

<h2> Yeni CD Ekle</h2>

<form asp-action="Ekle" method="post" enctype="multipart/form-data">

    <div class="form-group" style="margin-bottom:15px;">
        <label class="form-label">CD Adı</label>
        <input asp-for="Ad" class="form-control" placeholder="CD'nin Adını Giriniz" required />
    </div>

    <div class="form-group" style="margin-bottom:15px;">
        <label class="form-label">CD Fotoğrafı</label>
        <input type="file" name="Foto" class="form-control" placeholder="CD'nin Fotoğrafını Ekleyiniz" required />
    </div>

    <div class="form-group" style="margin-bottom:15px;">
        <label class="form-label">Grup</label>
        <select asp-for="GrupId" asp-items="ViewBag.GrupListesi" class="form-control" required>
            <option value="">--Lütfen Bir Grup Seçin--</option>
        </select>
    </div>

    <div class="form-group" style="margin-bottom:15px;">
        <label class="form-label">Stok Miktarı</label>
        <input asp-for="Stock" type="number" class="form-control" placeholder="Stok miktarını giriniz" min="0" required />
    </div>

    <button type="submit" class="btn btn-primary">Kaydet</button>
    <a asp-action="Index" class="btn btn-secondary" style="margin-left:10px;">İptal et ve Listeye dön</a>
</form>
