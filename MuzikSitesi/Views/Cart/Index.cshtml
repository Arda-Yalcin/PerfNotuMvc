@model List<MuzikSitesi.Models.CartItem>

<h2>Sepetim</h2>

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger">@TempData["Error"]</div>
}

@if (!Model.Any())
{
    <div class="alert alert-info">
        Sepetinizde CD bulunmuyor. CD eklemek için <a asp-controller="Cd" asp-action="Index">CD listesine</a> gidin.
    </div>
}
else
{
    <table class="table table-bordered">
        <thead>
            <tr>
                <th>CD</th>
                <th>Stok</th>
                <th>Adet</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                var stock = item.Cd?.Stock ?? 0;
                <tr>
                    <td>@item.Cd?.Ad</td>
                    <td>@stock</td>
                    <td style="width: 200px;">
                        <form asp-action="UpdateQuantity" asp-controller="Cart" method="post" class="d-flex align-items-center gap-2">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="id" value="@item.Id" />
                            <input type="number" name="quantity" value="@item.Quantity" min="1" max="@stock" class="form-control" style="max-width: 100px;" />
                            <button type="submit" class="btn btn-primary">Güncelle</button>
                        </form>
                    </td>
                    <td>
                        <form asp-action="Remove" asp-controller="Cart" method="post">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="id" value="@item.Id" />
                            <button type="submit" class="btn btn-outline-danger">Kaldır</button>
                        </form>
                    </td>
                </tr>
            }
        </tbody>
    </table>

    <form asp-action="RentCart" asp-controller="Cart" method="post" class="text-end">
        @Html.AntiForgeryToken()
        <button type="submit" class="btn btn-warning">Kiralama Talebi Gönder</button>
    </form>
}
