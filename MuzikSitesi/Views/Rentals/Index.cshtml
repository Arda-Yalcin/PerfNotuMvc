@model List<MuzikSitesi.Models.CdRental>

@{
    var isAdmin = User?.IsInRole("Admin") == true;
    var overdueCount = Model.Count(r => r.IsApproved
        && !r.IsReturned
        && r.ApprovalDate.HasValue
        && r.ApprovalDate.Value.AddDays(15) < DateTime.UtcNow);
}

<h2>@(isAdmin ? "Kiralama Talepleri" : "Kiralamalarım")</h2>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success">@TempData["Success"]</div>
}

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger">@TempData["Error"]</div>
}

<div class="alert alert-warning">
    Kiralama ve iade işlemleri yönetici onayından sonra tamamlanır. Kiralama süresi onaydan itibaren <strong>15 gün</strong> kabul edilir.
</div>

@if (overdueCount > 0)
{
    <div class="alert alert-danger fw-bold" role="alert">
        @overdueCount adet kiralamanın son iade tarihi geçti. Kırmızı satırları kontrol edin.
    </div>
}

@if (!Model.Any())
{
    <div class="alert alert-info">Henüz kiralama kaydı yok.</div>
}
else
{
    <table class="table table-striped align-middle">
        <thead>
            <tr>
                @if (isAdmin)
                {
                    <th>Üye</th>
                }
                <th>CD</th>
                <th>Grup</th>
                <th>Adet</th>
                <th>Talep Tarihi</th>
                <th>Onay Tarihi</th>
                <th>Son Teslim Tarihi</th>
                <th>Durum</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var rental in Model)
            {
                var dueDateUtc = rental.ApprovalDate?.AddDays(15);
                var dueDate = dueDateUtc?.ToLocalTime();
                var overdue = rental.IsApproved && !rental.IsReturned && dueDateUtc.HasValue && dueDateUtc.Value < DateTime.UtcNow;
                <tr class="@(overdue ? "table-danger overdue-rental-row" : "")">
                    @if (isAdmin)
                    {
                        <td>@(rental.AppUser?.Ad + " " + rental.AppUser?.Soyad)</td>
                    }
                    <td>@rental.Cd?.Ad</td>
                    <td>@rental.Cd?.Grup?.Ad</td>
                    <td>@rental.Quantity</td>
                    <td>@rental.RentDate.ToLocalTime().ToString("g")</td>
                    <td>@(rental.ApprovalDate?.ToLocalTime().ToString("g") ?? "-")</td>
                    <td class="@(overdue ? "fw-bold text-danger" : "")">@(dueDate?.ToString("g") ?? "-")</td>
                    <td>
                        @if (rental.IsReturned)
                        {
                            <span class="badge bg-success">İade Edildi</span>
                        }
                        else if (rental.ReturnRequested)
                        {
                            <span class="badge bg-warning text-dark">İade Onayı Bekliyor</span>
                        }
                        else if (!rental.IsApproved)
                        {
                            <span class="badge bg-secondary">Kiralama Onayı Bekliyor</span>
                        }
                        else if (overdue)
                        {
                            <span class="badge bg-danger">Süre Aşımı</span>
                        }
                        else
                        {
                            <span class="badge bg-primary">Kirada</span>
                        }
                    </td>
                    <td>
                        @if (isAdmin && !rental.IsApproved)
                        {
                            <form asp-action="ApproveRental" asp-controller="Rentals" method="post" class="d-inline">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="id" value="@rental.Id" />
                                <button type="submit" class="btn btn-success btn-sm">Kiralamayı Onayla</button>
                            </form>
                        }
                        else if (isAdmin && rental.IsApproved && !rental.IsReturned)
                        {
                            <form asp-action="@(rental.ReturnRequested ? "ApproveReturn" : "DirectReturn")" asp-controller="Rentals" method="post" class="d-inline">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="id" value="@rental.Id" />
                                <button type="submit" class="btn btn-danger btn-sm">@(rental.ReturnRequested ? "İadeyi Onayla" : "Direkt İade Al")</button>
                            </form>
                        }
                        else if (!isAdmin && rental.IsApproved && !rental.ReturnRequested && !rental.IsReturned)
                        {
                            <form asp-action="Return" asp-controller="Rentals" method="post">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="id" value="@rental.Id" />
                                <button type="submit" class="btn btn-outline-success btn-sm">İade Talebi Gönder</button>
                            </form>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
}
