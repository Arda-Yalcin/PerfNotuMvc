@model IEnumerable<AppUser>

@{
    ViewData["Title"] = "Kullanıcılar";
}

<h2>Kullanıcılar</h2>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success">@TempData["Success"]</div>
}

<table class="table table-striped align-middle">
    <thead>
        <tr>
            <th>Ad</th>
            <th>Soyad</th>
            <th>Email</th>
            <th>Telefon</th>
            <th>Adres</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var user in Model)
        {
            <tr>
                <td>@user.Ad</td>
                <td>@user.Soyad</td>
                <td>@user.Email</td>
                <td>@user.Telefon</td>
                <td>@user.Adres</td>
                <td>
                    <a asp-action="Edit" asp-route-id="@user.Id" class="btn btn-outline-primary btn-sm">Düzenle</a>
                </td>
            </tr>
        }
    </tbody>
</table>
